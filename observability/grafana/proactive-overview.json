{
  "title": "ProActive SEO Platform Overview",
  "uid": "proactive-overview",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {"type":"stat","title":"Request rate","gridPos":{"x":0,"y":0,"w":6,"h":5},"targets":[{"expr":"sum(rate(proactive_http_requests_total[5m]))"}]},
    {"type":"stat","title":"5xx rate","gridPos":{"x":6,"y":0,"w":6,"h":5},"targets":[{"expr":"sum(rate(proactive_http_requests_total{status=~\"5..\"}[5m]))"}]},
    {"type":"timeseries","title":"p95 latency by service","gridPos":{"x":0,"y":5,"w":12,"h":8},"targets":[{"expr":"histogram_quantile(0.95, sum by (le, service) (rate(proactive_http_request_duration_seconds_bucket[5m])))"}]},
    {"type":"timeseries","title":"Agent queue depth","gridPos":{"x":12,"y":5,"w":12,"h":8},"targets":[{"expr":"proactive_agent_queue_depth"}]}
  ]
}

